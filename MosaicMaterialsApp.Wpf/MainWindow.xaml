<Window x:Class="MosaicMaterialsApp.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Учет материалов"
        Height="820"
        Width="1220"
        WindowStartupLocation="CenterScreen"
        Icon="pack://siteoforigin:,,,/res/Mosaic.ico">
    <DockPanel LastChildFill="True">
        <Border DockPanel.Dock="Top"
                Background="{StaticResource SecondaryBackgroundBrush}">
            <Grid Margin="16,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="110" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Image Grid.Column="0"
                       Width="110"
                       Height="80"
                       Source="pack://siteoforigin:,,,/res/MosaicLogo.png"
                       Stretch="Uniform" />

                <StackPanel Grid.Column="2"
                            VerticalAlignment="Center">
                    <TextBlock FontSize="30"
                               FontWeight="Bold"
                               Text="Компания Мозаика" />
                    <TextBlock Margin="0,4,0,0"
                               FontSize="20"
                               Text="Список материалов" />
                </StackPanel>
            </Grid>
        </Border>

        <Border DockPanel.Dock="Bottom"
                BorderThickness="1,1,1,0"
                BorderBrush="{StaticResource BorderBrush}"
                Padding="8,8,8,10">
            <WrapPanel>
                <Button x:Name="AddMaterialButton"
                        Width="170"
                        Style="{StaticResource AccentButtonStyle}"
                        Click="AddMaterialButton_Click"
                        Content="Добавить" />
                <Button x:Name="EditMaterialButton"
                        Width="170"
                        Style="{StaticResource AccentButtonStyle}"
                        Click="EditMaterialButton_Click"
                        Content="Редактировать" />
                <Button x:Name="SuppliersButton"
                        Width="220"
                        Style="{StaticResource AccentButtonStyle}"
                        Click="SuppliersButton_Click"
                        Content="Поставщики материала" />
                <Button x:Name="CloseButton"
                        Width="110"
                        Style="{StaticResource AccentButtonStyle}"
                        Click="CloseButton_Click"
                        Content="Выйти" />
            </WrapPanel>
        </Border>

        <Grid Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.3*" />
                <ColumnDefinition Width="10" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <ListBox x:Name="MaterialsListBox"
                     Grid.Column="0"
                     SelectionMode="Single"
                     BorderThickness="0"
                     Background="Transparent"
                     MouseDoubleClick="MaterialsListBox_MouseDoubleClick">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="HorizontalContentAlignment"
                                Value="Stretch" />
                        <Setter Property="Margin"
                                Value="0,0,0,10" />
                    </Style>
                </ListBox.ItemContainerStyle>

                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1"
                                Padding="12"
                                CornerRadius="4"
                                Background="{StaticResource MainBackgroundBrush}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel>
                                    <TextBlock FontSize="17"
                                               FontWeight="Bold"
                                               Text="{Binding Title}" />
                                    <TextBlock Margin="0,4,0,0"
                                               Text="{Binding UnitPriceText, StringFormat=Цена: {0} руб.}" />
                                    <TextBlock Margin="0,2,0,0"
                                               Text="{Binding StockInfo, StringFormat=Остаток: {0}}" />
                                    <TextBlock Margin="0,2,0,0"
                                               Text="{Binding MinInfo, StringFormat=Минимум: {0}}" />
                                    <TextBlock Margin="0,2,0,0"
                                               Text="{Binding PackInfo, StringFormat=В упаковке: {0}}" />
                                </StackPanel>

                                <Border Grid.Column="1"
                                        Margin="14,0,0,0"
                                        Padding="10,6"
                                        BorderThickness="1"
                                        BorderBrush="{StaticResource AccentBrush}"
                                        Background="{StaticResource SecondaryBackgroundBrush}">
                                    <StackPanel>
                                        <TextBlock FontSize="13"
                                                   FontWeight="SemiBold"
                                                   Text="Мин. партия" />
                                        <TextBlock Margin="0,2,0,0"
                                                   FontSize="18"
                                                   FontWeight="Bold"
                                                   Text="{Binding MinimalPurchaseCostText, StringFormat={}{0} руб.}" />
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <Border Grid.Column="2"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    Padding="10">
                <StackPanel>
                    <TextBlock FontSize="19"
                               FontWeight="Bold"
                               Text="Расчет количества продукции" />

                    <Grid Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="220" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="44" />
                            <RowDefinition Height="44" />
                            <RowDefinition Height="44" />
                            <RowDefinition Height="44" />
                            <RowDefinition Height="44" />
                            <RowDefinition Height="44" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
                                   Style="{StaticResource FormLabelTextBlockStyle}"
                                   Text="Тип продукции" />
                        <ComboBox x:Name="ProductTypeComboBox"
                                  Grid.Row="0"
                                  Grid.Column="1"
                                  DisplayMemberPath="Name" />

                        <TextBlock Grid.Row="1"
                                   Style="{StaticResource FormLabelTextBlockStyle}"
                                   Text="Тип материала" />
                        <ComboBox x:Name="MaterialTypeComboBox"
                                  Grid.Row="1"
                                  Grid.Column="1"
                                  DisplayMemberPath="Name" />

                        <TextBlock Grid.Row="2"
                                   Style="{StaticResource FormLabelTextBlockStyle}"
                                   Text="Количество сырья" />
                        <TextBox x:Name="RawAmountTextBox"
                                 Grid.Row="2"
                                 Grid.Column="1"
                                 Text="1" />

                        <TextBlock Grid.Row="3"
                                   Style="{StaticResource FormLabelTextBlockStyle}"
                                   Text="Параметр 1" />
                        <TextBox x:Name="Parameter1TextBox"
                                 Grid.Row="3"
                                 Grid.Column="1"
                                 Text="1" />

                        <TextBlock Grid.Row="4"
                                   Style="{StaticResource FormLabelTextBlockStyle}"
                                   Text="Параметр 2" />
                        <TextBox x:Name="Parameter2TextBox"
                                 Grid.Row="4"
                                 Grid.Column="1"
                                 Text="1" />

                        <Button x:Name="CalculateButton"
                                Grid.Row="5"
                                Grid.Column="1"
                                Width="160"
                                HorizontalAlignment="Left"
                                Style="{StaticResource AccentButtonStyle}"
                                Click="CalculateButton_Click"
                                Content="Рассчитать" />
                    </Grid>

                    <TextBlock x:Name="CalculationResultTextBlock"
                               Margin="0,10,0,0"
                               FontSize="20"
                               FontWeight="Bold"
                               Text="Результат: -" />
                </StackPanel>
            </Border>
        </Grid>
    </DockPanel>
</Window>
