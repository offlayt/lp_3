<Window x:Class="MosaicMaterialsApp.Wpf.MaterialEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Материал"
        Height="650"
        Width="780"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Icon="pack://siteoforigin:,,,/res/Mosaic.ico">
    <DockPanel LastChildFill="True">
        <Border DockPanel.Dock="Top"
                Background="{StaticResource SecondaryBackgroundBrush}"
                Padding="16,14">
            <TextBlock x:Name="TitleTextBlock"
                       FontSize="24"
                       FontWeight="Bold" />
        </Border>

        <Border DockPanel.Dock="Bottom"
                BorderThickness="1,1,1,0"
                BorderBrush="{StaticResource BorderBrush}"
                Padding="8,8,8,10">
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button x:Name="SaveButton"
                        Width="140"
                        IsDefault="True"
                        Style="{StaticResource AccentButtonStyle}"
                        Click="SaveButton_Click"
                        Content="Сохранить" />
                <Button x:Name="CancelButton"
                        Width="120"
                        IsCancel="True"
                        Style="{StaticResource AccentButtonStyle}"
                        Click="CancelButton_Click"
                        Content="Назад" />
            </StackPanel>
        </Border>

        <Grid Margin="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="270" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="48" />
                <RowDefinition Height="48" />
                <RowDefinition Height="48" />
                <RowDefinition Height="48" />
                <RowDefinition Height="48" />
                <RowDefinition Height="48" />
                <RowDefinition Height="48" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Style="{StaticResource FormLabelTextBlockStyle}"
                       Text="Наименование" />
            <TextBox x:Name="NameTextBox"
                     Grid.Row="0"
                     Grid.Column="1" />

            <TextBlock Grid.Row="1"
                       Style="{StaticResource FormLabelTextBlockStyle}"
                       Text="Тип материала" />
            <ComboBox x:Name="MaterialTypeComboBox"
                      Grid.Row="1"
                      Grid.Column="1"
                      DisplayMemberPath="Name"
                      SelectedValuePath="Id" />

            <TextBlock Grid.Row="2"
                       Style="{StaticResource FormLabelTextBlockStyle}"
                       Text="Количество на складе" />
            <TextBox x:Name="StockQuantityTextBox"
                     Grid.Row="2"
                     Grid.Column="1" />

            <TextBlock Grid.Row="3"
                       Style="{StaticResource FormLabelTextBlockStyle}"
                       Text="Единица измерения" />
            <TextBox x:Name="UnitTextBox"
                     Grid.Row="3"
                     Grid.Column="1" />

            <TextBlock Grid.Row="4"
                       Style="{StaticResource FormLabelTextBlockStyle}"
                       Text="Количество в упаковке" />
            <TextBox x:Name="PackQuantityTextBox"
                     Grid.Row="4"
                     Grid.Column="1" />

            <TextBlock Grid.Row="5"
                       Style="{StaticResource FormLabelTextBlockStyle}"
                       Text="Минимальное количество" />
            <TextBox x:Name="MinQuantityTextBox"
                     Grid.Row="5"
                     Grid.Column="1" />

            <TextBlock Grid.Row="6"
                       Style="{StaticResource FormLabelTextBlockStyle}"
                       Text="Цена единицы материала" />
            <TextBox x:Name="UnitPriceTextBox"
                     Grid.Row="6"
                     Grid.Column="1" />
        </Grid>
    </DockPanel>
</Window>
